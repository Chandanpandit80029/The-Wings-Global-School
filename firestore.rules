rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users collection - only admins can read/write
    match /users/{userId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && request.resource.data.role == 'admin';
      allow update, delete: if isAdmin() && request.auth.uid == userId;
    }

    // Announcements - public read, admin write
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // News - public read, admin write
    match /news/{newsId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Events - public read, admin write
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Faculty - public read, admin write
    match /faculty/{facultyId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Gallery - public read, admin write
    match /gallery/{galleryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Downloads - public read, admin write
    match /downloads/{downloadId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Slider - public read, admin write
    match /slider/{slideId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Hero Slider - public read, admin write
    match /heroSlider/{slideId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admissions - admin read/write, public create (for form submissions)
    match /admissions/{admissionId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'phone']);
    }

    // Messages - admin read/write, public create (for contact form)
    match /messages/{messageId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message']);
    }

    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}